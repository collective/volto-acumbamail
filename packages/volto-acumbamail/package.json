{
  "name": "volto-acumbamail",
  "version": "1.0.0",
  "description": "A volto add-on that integrates Acumbamail service with Plone",
  "author": "Leonardo J. Caballero G.",
  "homepage": "https://github.com/collective/volto-acumbamail#readme",
  "main": "src/index.ts",
  "license": "MIT",
  "keywords": [
    "volto-addon",
    "volto",
    "plone",
    "react",
    "Acumbamail",
    "integration"
  ],
  "repository": {
    "type": "git",
    "url": "git@github.com:collective/volto-acumbamail.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "i18n": "rm -rf build/messages && NODE_ENV=production i18n --addon",
    "dry-release": "release-it --dry-run",
    "release": "release-it",
    "release-major-alpha": "release-it major --preRelease=alpha",
    "release-alpha": "release-it --preRelease=alpha"
  },
  "dependencies": {
    "@plone/components": "workspace:*"
  },
  "peerDependencies": {
    "classnames": "2.5.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-intl": "^3.12.1"
  },
  "devDependencies": {
    "@plone/types": "workspace:*",
    "@plone/scripts": "^3.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "release-it": "^19.0.2"
  }
}
